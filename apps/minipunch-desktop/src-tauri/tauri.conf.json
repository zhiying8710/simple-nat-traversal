{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniPunch Desktop",
  "version": "0.1.0",
  "identifier": "com.minipunch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MiniPunch 桌面端",
        "width": 1420,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src blob: data: filesystem: ws: wss: http: https: tauri: asset: 'unsafe-inline' 'unsafe-eval' 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
